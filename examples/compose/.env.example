# Komodo MCP Server Configuration
# Copy this file to .env and adjust the values

# Optional: Image tag (default: latest)
KOMODO_MCP_IMAGE_TAG=latest

# --- Komodo Connection ---

# Komodo Server URL
# Examples:
#   - Local: https://localhost:9120 or https://127.0.0.1:9120
#   - Remote: https://komodo.example.com:9120
#   - Docker: https://host.docker.internal:9120
KOMODO_URL=https://komodo.example.com:9120

# Komodo API Key (Recommended)
# Obtain this from your Komodo server configuration
KOMODO_API_KEY=your-komodo-api-key
KOMODO_API_SECRET=your-komodo-api-secret

# Komodo Authentication (Alternative)
# Create a dedicated user in Komodo for the MCP server
# Recommended: Create a dedicated user with read-only or limited permissions
KOMODO_USERNAME=mcp-user
KOMODO_PASSWORD=your-secure-password

# --- MCP Configuration ---

# Transport Mode
# default: http
# Options:
#   - http:   For remote usage via HTTP (exposes port 3000)
#   - stdio:  For local usage via 'docker exec' (Claude Desktop, VS Code)
MCP_TRANSPORT=http

# Legacy SSE Transport (deprecated)
# Enable backwards compatibility for older MCP clients using HTTP+SSE transport
# Default: false (only Streamable HTTP Transport enabled)
# Note: This option is only available when MCP_TRANSPORT is set to 'http'
MCP_LEGACY_SSE_ENABLED=false

# Bind Host (only used in HTTP/SSE mode)
# Default 0.0.0.0
MCP_BIND_HOST=0.0.0.0

# Server Port (only used in HTTP/SSE mode)
# Default: 3000
MCP_PORT=3000

# Allowed Origins (only used in HTTP/SSE mode)
# Comma-separated list of allowed origins for CORS and DNS rebinding protection
# Default: * (allows all)
# Example:  MCP_ALLOWED_ORIGINS=localhost,example.com
MCP_ALLOWED_ORIGINS=*

# --- Connection Health Monitor ---

# Enable automatic reconnection when Komodo Core restarts or becomes unreachable.
# The monitor runs periodic health checks and reconnects using environment credentials.

# Health check interval in milliseconds (default: 30000 = 30 seconds)
# CONNECTION_MONITOR_INTERVAL_MS=30000

# Initial reconnection delay in milliseconds (default: 2000)
# Uses exponential backoff up to the max delay
# CONNECTION_MONITOR_RECONNECT_BASE_MS=2000

# Maximum reconnection delay in milliseconds (default: 60000 = 1 minute)
# CONNECTION_MONITOR_RECONNECT_MAX_MS=60000

# Maximum consecutive reconnection attempts before backing off (default: 10)
# After this limit, the monitor continues health checks but stops active reconnection
# until a health check succeeds (e.g., Komodo Core comes back on its own)
# CONNECTION_MONITOR_MAX_RECONNECT_ATTEMPTS=10

# --- Logging ---

# Log Level
# Sets the verbosity of the logs
# Default: info
# Options: trace, debug, info, warn, error
LOG_LEVEL=info

# Log Format
# Defines the format of the log output
# Default: text
# Options: text, json
LOG_FORMAT=text

# Log Directory
# Sets the directory where log files will be stored
# Optional: If set, logs will be written to files in the specified directory
# LOG_DIR=/var/log/komodo-mcp

# --- OpenTelemetry (Observability) ---

# Enable OpenTelemetry
# When enabled, the server will export traces and metrics to an OTLP-compatible backend
# Default: false
OTEL_ENABLED=false

# OpenTelemetry Service Name
# The name that will appear in your tracing/metrics backend
# Default: mcp-server
OTEL_SERVICE_NAME=komodo-mcp-server

# OTLP Exporter Endpoint
# The URL of your OTLP-compatible collector (e.g., Jaeger, Grafana Tempo, OpenTelemetry Collector)
# Examples:
#   - Jaeger: http://jaeger:4318
#   - Grafana Tempo: http://tempo:4318
#   - OpenTelemetry Collector: http://otel-collector:4318
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# OpenTelemetry Debug Mode
# Enables verbose debug logging for OpenTelemetry internals
# Default: false
OTEL_DEBUG=false
